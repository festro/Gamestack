#!/bin/bash
# GameStack Launcher
# Status dashboard and control panel for the GameStack stack.
# Run from anywhere: bash ~/Git/Gamestack/gamestack
# Or make executable and add ~/Git/Gamestack to PATH: gamestack

cd "$(dirname "$0")"

# Load .env if present
[ -f .env ] && set -a && source .env && set +a

# ── Colours ───────────────────────────────────────────────────────────────────
R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'
C='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────────────────
container_status() {
    local state
    state=$(docker inspect --format='{{.State.Status}}' "$1" 2>/dev/null)
    case "$state" in
        running)               echo "running" ;;
        exited|created|paused) echo "stopped" ;;
        *)                     echo "missing" ;;
    esac
}

status_icon() {
    case "$1" in
        running) printf "${G}●${RESET}" ;;
        stopped) printf "${R}●${RESET}" ;;
        missing) printf "${DIM}○${RESET}" ;;
    esac
}

get_host_ip() {
    ip route get 1.1.1.1 2>/dev/null \
        | awk '/src/{for(i=1;i<=NF;i++) if($i=="src") print $(i+1); exit}' \
        || echo "localhost"
}

is_remote() {
    [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ] || [ -n "$SSH_CONNECTION" ]
}

open_browser() {
    local url="$1"
    is_remote && return 1
    if   command -v xdg-open &>/dev/null; then xdg-open "$url" &>/dev/null &
    elif command -v wslview  &>/dev/null; then wslview  "$url" &>/dev/null &
    elif command -v open     &>/dev/null; then open     "$url" &>/dev/null &
    elif command -v gio      &>/dev/null; then gio open "$url" &>/dev/null &
    else return 1
    fi
    return 0
}

log_cmd() {
    # log_cmd <label> <docker compose args...>
    local label="$1"; shift
    local log_dir log_file

    log_dir=$(grep "^DATA_DIR=" .env 2>/dev/null | cut -d= -f2 | tr -d '"' | sed "s|~|$HOME|g")
    log_dir="${log_dir:-$(pwd)}"
    mkdir -p "${log_dir}/logs"
    log_file="${log_dir}/logs/${label}-$(date +%Y%m%d-%H%M%S).log"

    echo "GameStack ${label} — $(date)" > "$log_file"
    echo -e "  ${DIM}Logging to: ${log_file}${RESET}"

    if [ -f .env ]; then
        docker compose --env-file .env "$@" 2>&1 | tee -a "$log_file"
    else
        docker compose "$@" 2>&1 | tee -a "$log_file"
    fi
}

is_configured() {
    [ -f .env ] && ! grep -q "your_amp_username\|02:42:xx" .env 2>/dev/null
}

draw_header() {
    clear
    local HOST_IP
    HOST_IP=$(get_host_ip)

    echo -e "${BOLD}"
    echo "  ╔══════════════════════════════════════════╗"
    echo "  ║             GameStack                    ║"
    echo "  ╚══════════════════════════════════════════╝"
    echo -e "${RESET}"

    # Configuration status
    if ! is_configured; then
        echo -e "  ${Y}⚠  Stack not configured — run [c] Configure first${RESET}"
        echo ""
    fi

    # Container status
    echo -e "  ${DIM}Stack status${RESET}"
    local containers=("portal" "amp" "wolf" "wolf-webrtc")
    for c in "${containers[@]}"; do
        local s
        s=$(container_status "$c")
        printf "  %b  %-16s %b\n" "$(status_icon "$s")" "$c" "${DIM}${s}${RESET}"
    done

    echo ""
    echo -e "  ${DIM}Portal:${RESET} ${C}http://${HOST_IP}/${RESET}"
    echo ""
    echo -e "  ${DIM}────────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}[s]${RESET}  Start stack"
    echo -e "  ${BOLD}[d]${RESET}  Stop stack"
    echo -e "  ${BOLD}[r]${RESET}  Restart stack"
    echo -e "  ${BOLD}[o]${RESET}  Open portal in browser"
    echo -e "  ${BOLD}[c]${RESET}  Configure (first-time setup / reconfigure)"
    echo -e "  ${BOLD}[f]${RESET}  Refresh status"
    echo -e "  ${BOLD}[z]${RESET}  Sterilize (clean repo for git commit)"
    echo -e "  ${BOLD}[x]${RESET}  Exit"
    echo -e "  ${DIM}────────────────────────────────────────${RESET}"
    echo ""
}

anykey() {
    echo ""
    printf "  Press any key to continue..."
    read -rsn1
}

# ── Main loop ─────────────────────────────────────────────────────────────────
while true; do
    draw_header

    printf "  Choice: "
    read -rsn1 key
    echo ""

    case "$key" in

        s|S)
            echo ""
            if ! is_configured; then
                echo -e "  ${Y}Stack is not configured yet.${RESET}"
                echo -e "  ${DIM}Run [c] Configure before starting the stack.${RESET}"
                anykey; continue
            fi
            echo -e "  ${BOLD}Starting stack...${RESET}"
            echo ""
            log_cmd "start" up -d
            anykey
            ;;

        d|D)
            echo ""
            echo -e "  ${BOLD}Stopping stack...${RESET}"
            echo ""
            log_cmd "stop" down
            # Stop any Wolf child session containers
            WOLF_CHILDREN=$(docker ps -a --filter "name=Wolf" --format "{{.Names}}" 2>/dev/null)
            if [ -n "$WOLF_CHILDREN" ]; then
                echo ""
                echo -e "  ${DIM}Stopping Wolf session containers...${RESET}"
                echo "$WOLF_CHILDREN" | xargs docker rm -f 2>/dev/null || true
            fi
            anykey
            ;;

        r|R)
            echo ""
            if ! is_configured; then
                echo -e "  ${Y}Stack is not configured yet.${RESET}"
                echo -e "  ${DIM}Run [c] Configure before starting the stack.${RESET}"
                anykey; continue
            fi
            echo -e "  ${BOLD}Restarting stack...${RESET}"
            echo ""
            WOLF_CHILDREN=$(docker ps -a --filter "name=Wolf" --format "{{.Names}}" 2>/dev/null | grep -v "^wolf$|^wolf-webrtc$|^WolfPulseAudio$")
            [ -n "$WOLF_CHILDREN" ] && echo "$WOLF_CHILDREN" | xargs docker rm -f 2>/dev/null || true
            log_cmd "restart" restart
            anykey
            ;;

        o|O)
            HOST_IP=$(get_host_ip)
            PORTAL_URL="http://${HOST_IP}/"
            echo ""
            if is_remote; then
                echo -e "  ${Y}Remote/SSH session — cannot open browser on server.${RESET}"
                echo -e "  Open this URL on your local machine:"
                echo ""
                echo -e "    ${C}${BOLD}${PORTAL_URL}${RESET}"
            else
                echo -e "  Opening ${C}${PORTAL_URL}${RESET}..."
                if open_browser "$PORTAL_URL"; then
                    echo -e "  ${G}Browser launched.${RESET}"
                else
                    echo -e "  ${Y}Could not open a browser automatically.${RESET}"
                    echo -e "  Open this URL manually:"
                    echo ""
                    echo -e "    ${C}${BOLD}${PORTAL_URL}${RESET}"
                fi
            fi
            anykey
            ;;

        c|C)
            echo ""
            if [ -f configure.sh ]; then
                bash configure.sh
            else
                echo -e "  ${R}configure.sh not found in $(pwd)${RESET}"
            fi
            anykey
            ;;

        z|Z)
            echo ""
            if [ -f sterilize.sh ]; then
                bash sterilize.sh
            else
                echo -e "  ${R}sterilize.sh not found in $(pwd)${RESET}"
            fi
            anykey
            ;;

        f|F)
            # Redraw happens automatically at top of loop
            ;;

        x|X|$'\x1b')
            echo ""
            exit 0
            ;;

        *)
            # Unrecognised key — just redraw
            ;;
    esac
done
