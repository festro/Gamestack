#!/bin/bash
# GameStack Launcher
# Run from anywhere: bash ~/Gamestack/gamestack
# Or make executable and add ~/Gamestack to PATH for just: gamestack

cd "$(dirname "$0")"

# Load .env if present so DATA_DIR and other vars are available
[ -f .env ] && set -a && source .env && set +a

# ── Colours ───────────────────────────────────────────────────────────────────
R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m'
B='\033[0;34m' C='\033[0;36m' BOLD='\033[1m' DIM='\033[2m' RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────────────────
container_status() {
    # Returns "running", "stopped", or "missing"
    local name="$1"
    local state
    state=$(docker inspect --format='{{.State.Status}}' "$name" 2>/dev/null)
    case "$state" in
        running)  echo "running"  ;;
        exited|created|paused) echo "stopped" ;;
        *)        echo "missing"  ;;
    esac
}

status_icon() {
    case "$1" in
        running) printf "${G}●${RESET}" ;;
        stopped) printf "${R}●${RESET}" ;;
        missing) printf "${DIM}○${RESET}" ;;
    esac
}

get_host_ip() {
    ip route get 1.1.1.1 2>/dev/null | awk '/src/{for(i=1;i<=NF;i++) if($i=="src") print $(i+1); exit}' || echo "localhost"
}

is_remote_session() {
    # Returns true if running over SSH or on a headless system with no display
    [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ] || [ -n "$SSH_CONNECTION" ]
}

open_browser() {
    local url="$1"

    if is_remote_session; then
        return 1  # Signal to caller to print URL instead
    fi

    # Try platform-specific openers in order
    if   command -v xdg-open &>/dev/null; then xdg-open  "$url" &>/dev/null &
    elif command -v wslview  &>/dev/null; then wslview   "$url" &>/dev/null &
    elif command -v open     &>/dev/null; then open      "$url" &>/dev/null &
    elif command -v gio       &>/dev/null; then gio open  "$url" &>/dev/null &
    else return 1
    fi
    return 0
}

draw_header() {
    clear
    local HOST_IP
    HOST_IP=$(get_host_ip)
    local PORTAL_URL="http://${HOST_IP}/"

    echo -e "${BOLD}"
    echo "  ╔══════════════════════════════════════════╗"
    echo "  ║             GameStack                    ║"
    echo "  ╚══════════════════════════════════════════╝"
    echo -e "${RESET}"

    # Container status
    echo -e "  ${DIM}Stack status${RESET}"
    local containers=("portal" "amp" "wolf" "wolf-webrtc")
    for c in "${containers[@]}"; do
        local s
        s=$(container_status "$c")
        printf "  %b  %-14s %b\n" "$(status_icon "$s")" "$c" "${DIM}${s}${RESET}"
    done

    echo ""
    echo -e "  ${DIM}Portal:${RESET} ${C}${PORTAL_URL}${RESET}"
    echo ""
    echo -e "  ${DIM}────────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}[o]${RESET}  Open portal in browser"
    echo -e "  ${BOLD}[s]${RESET}  Start stack"
    echo -e "  ${BOLD}[d]${RESET}  Stop stack"
    echo -e "  ${BOLD}[r]${RESET}  Restart stack"
    echo -e "  ${BOLD}[q]${RESET}  Quicksetup wizard"
    echo -e "  ${BOLD}[x]${RESET}  Exit"
    echo -e "  ${DIM}────────────────────────────────────────${RESET}"
    echo ""
}

log_cmd() {
    # log_cmd <label> <command...>
    # Runs a docker compose command, tees output to a timestamped log file
    local label="$1"; shift
    local log_file
    # Use DATA_DIR from .env if available, else fall back to current dir
    local log_dir
    if [ -f .env ]; then
        log_dir=$(grep "^DATA_DIR=" .env | cut -d= -f2 | tr -d '"' | sed "s|~|$HOME|g")
    fi
    log_dir="${log_dir:-$(pwd)}"
    mkdir -p "${log_dir}/logs"
    log_file="${log_dir}/logs/${label}-$(date +%Y%m%d-%H%M%S).log"
    echo "GameStack ${label} log — $(date)" > "$log_file"
    echo -e "  ${DIM}Logging to: ${log_file}${RESET}"
    if [ -f .env ]; then
        docker compose --env-file .env --project-directory "$(dirname "$0")" "$@" 2>&1 | tee -a "$log_file"
    else
        docker compose "$@" 2>        docker compose "$@" 2>        "$@" 2>&1 | tee -a "$log_file"1 | tee -a "$log_file"1 | tee -a "$log_file"
    fi
}

# ── Main loop ─────────────────────────────────────────────────────────────────
while true; do
    draw_header

    printf "  Choice: "
    read -rsn1 key
    echo ""

    case "$key" in

        o|O)
            local HOST_IP
            HOST_IP=$(get_host_ip)
            PORTAL_URL="http://${HOST_IP}/"
            echo ""
            if is_remote_session; then
                echo ""
                echo -e "  ${Y}Remote/SSH session detected — cannot open browser on server.${RESET}"
                echo -e "  Open this URL on your local machine:"
                echo ""
                echo -e "    ${C}${BOLD}${PORTAL_URL}${RESET}"
            else
                echo -e "  Opening ${C}${PORTAL_URL}${RESET}..."
                if open_browser "$PORTAL_URL"; then
                    echo -e "  ${G}Browser launched.${RESET}"
                else
                    echo -e "  ${Y}Could not detect a browser opener.${RESET}"
                    echo -e "  Open this URL on your local machine:"
                    echo ""
                    echo -e "    ${C}${BOLD}${PORTAL_URL}${RESET}"
                fi
            fi
            echo ""
            printf "  Press any key to continue..."
            read -rsn1
            ;;

        s|S)
            echo ""
            echo -e "  ${BOLD}Starting stack...${RESET}"
            echo ""
            log_cmd "start" up -d
            echo ""
            printf "  Press any key to continue..."
            read -rsn1
            ;;

        d|D)
            echo ""
            echo -e "  ${BOLD}Stopping stack...${RESET}"
            echo ""
            log_cmd "stop" down
            # Also stop Wolf child containers (app sessions)
            WOLF_CHILDREN=$(docker ps -a --filter "name=Wolf" --format "{{.Names}}" 2>/dev/null)
            if [ -n "$WOLF_CHILDREN" ]; then
                echo ""
                echo -e "  ${DIM}Stopping Wolf session containers...${RESET}"
                echo "$WOLF_CHILDREN" | xargs docker rm -f 2>/dev/null || true
            fi
            echo ""
            printf "  Press any key to continue..."
            read -rsn1
            ;;

        r|R)
            echo ""
            echo -e "  ${BOLD}Restarting stack...${RESET}"
            echo ""
            log_cmd "restart" restart
            echo ""
            printf "  Press any key to continue..."
            read -rsn1
            ;;

        q|Q)
            echo ""
            if [ -f quicksetup.sh ]; then
                bash quicksetup.sh
            else
                echo -e "  ${R}quicksetup.sh not found in $(pwd)${RESET}"
                printf "  Press any key to continue..."
                read -rsn1
            fi
            ;;

        x|X|$'\x1b')
            echo ""
            exit 0
            ;;

        *)
            # Any unrecognised key just redraws
            ;;
    esac
done
