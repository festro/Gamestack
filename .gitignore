# ── Secrets & credentials ─────────────────────────────────────────────────────
.env

# ── Wolf runtime config ───────────────────────────────────────────────────────
# Contains paired client certificates, server TLS key/cert, and session data.
# Never commit. Use config.toml.example as your starting template.
wolf-config/

# ── AMP runtime data ──────────────────────────────────────────────────────────
# Contains AMP instance configs and game server data.
ampdata/

# ── Image cache ───────────────────────────────────────────────────────────────
images/

# ── Portal deploy-time files ──────────────────────────────────────────────────
# GameStack.html is copied here from output/ at deploy time.
portal/docs/

# ── Build outputs ─────────────────────────────────────────────────────────────
# Track the HTML doc (text). Ignore the binary docx.
output/GameStack.docx

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

logs/
.preflight_env

# ── Configured/generated output files ───────────────────────────────────────
# Generated by build.js and configured by configure.sh/quicksetup.sh.
# Contain live system values — never commit.
output/GameStack.html
output/GameStack.docx
