# GameStack Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Host ─────────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=America/Los_Angeles

# Absolute path to the Gamestack directory on the host.
# All container data (ampdata, wolf-config, portal files) lives here.
# Must match the location you cloned/extracted to.
DATA_DIR=~/Git/Gamestack

# ── AMP ──────────────────────────────────────────────────────────────────────
AMP_USERNAME=your_amp_username
AMP_PASSWORD=your_amp_password
AMP_LICENCE=your_amp_licence_key

# Fixed MAC address — prevents AMP licence deactivation on container restart.
# Generate one: printf '02:42:%02x:%02x:%02x:%02x\n' $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256))
AMP_MAC=02:42:xx:xx:xx:xx

# ── Game Ports ────────────────────────────────────────────────────────────────
# Set these to the ports required by whichever game server you run in AMP.
# Add more GAME_PORT_n variables as needed for additional servers.
GAME_PORT_1=9876
GAME_PORT_2=9877

# ── Wolf WebRTC Sidecar ───────────────────────────────────────────────────────
# Optional — comma-separated Wolf session IDs to pre-start on sidecar boot.
# Session IDs are the numeric folder names under wolf-config/cfg/ after pairing.
# Leave blank to connect on-demand via the portal.
WOLF_SESSION_IDS=
